        "catalogs": [
          "./.claude/uxml-lsp/catalog.xml",
          "file://${CLAUDE_PLUGIN_ROOT}/schemas/catalog.xml"
        ],
        "fileAssociations": [
          {
            "pattern": "**/*.uxml",
            "systemId": "urn:ui-toolkit-lsps:uxml"
          }
        ],
        "validation": {
          "enabled": true
        },
        "format": {
          "enabled": true
        }
      }
    },
